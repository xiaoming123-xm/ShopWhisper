# ============ 后端环境变量示例 ============
# 复制此文件为 .env 并填入实际值
# 开发环境可参考 .env.development 的默认配置
# 生产环境可参考 .env.production.template 的配置模板

# ============ 基础配置 ============
APP_NAME=电商智能客服系统
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ============ 数据库配置 (Docker内部) ============
DATABASE_URL=postgresql+asyncpg://ecom_user:ecom_password@postgres:5432/shop_whisper
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis (Docker内部)
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ============ JWT密钥 (必填：生产环境必须使用强密钥) ============
# 使用 openssl rand -hex 32 生成强密钥
JWT_SECRET=your-strong-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ API Key ============
API_KEY_PREFIX=eck_
API_KEY_LENGTH=32

# ============ OpenAI 配置 (使用DeepSeek API) ============
# 必填：实际的 DeepSeek API Key
OPENAI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============ Anthropic (可选) ============
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ============ Milvus 向量数据库 (云端服务) ============
# 必填：实际的 Milvus URI 和 Token
MILVUS_URI=https://your-milvus-instance.cloud.zilliz.com
MILVUS_TOKEN=your-milvus-token-here

# ============ Embedding 配置 ============
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============ 存储配置 ============
STORAGE_BACKEND=tos

# ============ 火山引擎 TOS 配置 ============
# 必填：对象存储服务凭证
TOS_ACCESS_KEY=your-tos-access-key-here
TOS_SECRET_KEY=your-tos-secret-key-here
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=your-bucket-name

# ============ RabbitMQ (Docker内部) ============
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============ 限流配置 ============
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============ 监控 (可选) ============
PROMETHEUS_PORT=9090
SENTRY_DSN=

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ 支付宝官方 SDK 配置 (可选) ============
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/callback/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/payment/result
ALIPAY_SANDBOX=false
ALIPAY_SANDBOX_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ============ 邮件服务 (可选) ============
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ============ Celery定时任务 ============
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=false
