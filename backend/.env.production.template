# ============ 生产环境配置模板 ============
# 部署到生产环境时，复制此文件为 .env 并填入实际值
# 注意：此文件可以提交到版本控制，但不包含敏感信息

# ============ 基础配置 ============
APP_NAME=电商智能客服系统
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["https://yourdomain.com"]

# ============ 数据库配置 ============
# 生产环境：使用实际的数据库地址和强密码
DATABASE_URL=postgresql+asyncpg://your_db_user:your_strong_password@postgres:5432/shop_whisper
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=100

# ============ JWT密钥 (必须修改为强密钥) ============
# 使用以下命令生成强密钥: openssl rand -hex 32
JWT_SECRET=your-strong-secret-key-here-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ API Key ============
API_KEY_PREFIX=eck_
API_KEY_LENGTH=32

# ============ LLM 提供商配置 ============
LLM_PROVIDER=deepseek

# ============ OpenAI 兼容配置 ============
# 必填：实际的 API Key
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============ DeepSeek 配置 ============
# 必填：实际的 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============ Anthropic (可选) ============
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ============ Milvus 向量数据库 ============
# 必填：实际的 Milvus 服务地址和 Token
MILVUS_URI=https://your-milvus-instance.cloud.zilliz.com.cn
MILVUS_TOKEN=your-milvus-token-here

# ============ Embedding 配置 ============
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============ 存储配置 ============
STORAGE_BACKEND=tos

# ============ 火山引擎 TOS 配置 ============
# 注意：TOS 配置从根目录 .env.local 读取，无需在此重复定义

# ============ RabbitMQ ============
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============ 限流配置 ============
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ============ 监控 (可选) ============
PROMETHEUS_PORT=9090
SENTRY_DSN=

# ============ 日志 ============
LOG_LEVEL=WARNING
LOG_FORMAT=json

# ============ 支付宝官方 SDK 配置 ============
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-rsa2-private-key-content
ALIPAY_PUBLIC_KEY=your-alipay-platform-public-key-content
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/v1/payment/callback/alipay/notify
ALIPAY_RETURN_URL=https://yourdomain.com/payment/result
ALIPAY_SANDBOX=false
ALIPAY_SANDBOX_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ============ 邮件服务 ============
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@yourdomain.com

# ============ Celery定时任务 ============
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=false
