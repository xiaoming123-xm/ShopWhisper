# ============ 后端开发环境配置 ============
APP_NAME=电商智能客服系统
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
DEPLOY_ENV=development

API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://127.0.0.1","http://127.0.0.1:8000"]

DATABASE_URL=postgresql+asyncpg://ecom_user:ecom_password@postgres:5432/shop_whisper
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

API_KEY_PREFIX=eck_
API_KEY_LENGTH=32

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

STORAGE_BACKEND=tos
TOS_ACCESS_KEY=dev-placeholder
TOS_SECRET_KEY=dev-placeholder
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=shop-whisper

VOLCENGINE_API_KEY=dev-placeholder
VOLCENGINE_API_BASE=https://ark.cn-beijing.volces.com/api/v3

LLM_PROVIDER=volcengine
LLM_MODEL=dev-placeholder
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

EMBEDDING_PROVIDER=volcengine
EMBEDDING_MODEL=dev-placeholder
EMBEDDING_DIMENSION=2048

IMAGE_GEN_PROVIDER=volcengine
IMAGE_GEN_MODEL=dev-placeholder

VIDEO_GEN_PROVIDER=volcengine
VIDEO_GEN_MODEL=dev-placeholder

MILVUS_URI=
MILVUS_TOKEN=

LOG_LEVEL=INFO
LOG_FORMAT=json
